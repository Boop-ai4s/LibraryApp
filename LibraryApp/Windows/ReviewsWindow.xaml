<Window x:Class="LibraryApp.Windows.ReviewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryApp.Windows"
        mc:Ignorable="d"
        Title="Комментарии и оценки" Height="500" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="Bold" Text="{Binding Book.Title}" Margin="0,0,0,10"/>
        <ListBox x:Name="ReviewsListBox" Grid.Row="1" Margin="0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D0E0F0" BorderThickness="1" Margin="2" Padding="5" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding User.Login}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" Margin="0,5"/>
                                <TextBlock Text="{Binding Rating, StringFormat='Оценка: {0}'}" Foreground="#555"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Удалить" Click="DeleteReview_Click" Tag="{Binding}" 
                                    Visibility="{Binding IsAdminVisible}" Margin="5,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Добавить свой комментарий" Click="AddComment_Click" Margin="5"/>
            <Button Content="Закрыть" Click="Close_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
