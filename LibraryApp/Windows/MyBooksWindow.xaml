<Window x:Class="LibraryApp.Windows.MyBooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryApp.Windows"
        mc:Ignorable="d"
        Title="Мои книги" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Обновить" Click="Refresh_Click" Margin="5,0"/>
            <Button Content="Назад к каталогу" Click="Back_Click" Margin="5,0"/>
        </StackPanel>
        <ListBox x:Name="MyBooksListBox" Grid.Row="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D0E0F0" BorderThickness="1" Margin="2" Padding="5" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Book.Title}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Book.Author.FullName}" FontSize="14"/>
                                <TextBlock Text="{Binding Book.Genre.Name}" FontSize="12" Foreground="#555"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="100" SelectedItem="{Binding Status, Mode=TwoWay}" Margin="5,0">
                                <ComboBoxItem Content="В планах"/>
                                <ComboBoxItem Content="Читаю"/>
                                <ComboBoxItem Content="Прочитано"/>
                            </ComboBox>
                            <Button Grid.Column="2" Content="-" ToolTip="Удалить из списка" Click="RemoveBook_Click" Tag="{Binding}" Margin="5,0"/>
                            <Button Grid.Column="3" Content="Добавить оценку" Click="AddRating_Click" Tag="{Binding}" Margin="5,0"/>
                            <Button Grid.Column="4" Content="Оставить комментарий" Click="AddComment_Click" Tag="{Binding}" Margin="5,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
