<Window x:Class="LibraryApp.Windows.RoleSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryApp.Windows"
        mc:Ignorable="d"
        Title="Выбор роли" Height="300" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Выберите вашу роль" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Margin="0,30,0,0" Grid.Row="0"/>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-30,0,0">
            <Button Content="Читатель" Width="200" Height="50" Margin="10" Click="ReaderButton_Click"/>
            <Button Content="Администратор" Width="200" Height="50" Margin="10" Click="AdminButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
