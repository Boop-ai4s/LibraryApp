<Window x:Class="LibraryApp.Windows.AdminCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryApp.Windows"
        mc:Ignorable="d"
        Title="Каталог книг (Администратор)" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить книгу" Click="AddBook_Click" Margin="5,0"/>
            <Button Content="Список пользователей" Click="ShowUsers_Click" Margin="5,0"/>
            <Button Content="Выйти" Click="Logout_Click" Margin="5,0" HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- Панель поиска -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Фильтр:"/>
            <ComboBox x:Name="FilterCombo" Width="120" SelectedIndex="0">
                <ComboBoxItem Content="Нет фильтра"/>
                <ComboBoxItem Content="По автору"/>
                <ComboBoxItem Content="По жанру"/>
                <ComboBoxItem Content="По алфавиту"/>
            </ComboBox>
            <TextBox x:Name="SearchBox" Width="200" TextChanged="SearchBox_TextChanged"/>
            <Button Content="Поиск" Click="Search_Click"/>
        </StackPanel>

        <!-- Список книг -->
        <ListBox x:Name="BooksListBox" Grid.Row="2" Grid.ColumnSpan="2" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D0E0F0" BorderThickness="1" Margin="2" Padding="5" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Author.FullName}" FontSize="14"/>
                                <TextBlock Text="{Binding Genre.Name}" FontSize="12" Foreground="#555"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="+" ToolTip="Добавить в мой список" Click="AddToMyBooks_Click" Tag="{Binding}" Margin="5,0"/>
                            <Button Grid.Column="2" Content="Комментарии и оценки" Click="ShowReviews_Click" Tag="{Binding}" Margin="5,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
